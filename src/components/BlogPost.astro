---
import { getCategories, categoryLabels, getTopicByKey, getTopicPath } from '../lib/categories.js';

const { post, locale } = Astro.props;
const { data, id } = post;
const slug = id.replace(`${locale}/`, '').replace('.md', '');

const cats = getCategories(data.tags || [], data.category);
const primaryCat = cats[0];
const categoryData = cats.join(',');
const postUrl = `/blog/${slug}`;
const topic = getTopicByKey(primaryCat);
const topicUrl = topic ? getTopicPath(topic) : '/topics';
---

<article class="post-card" data-categories={categoryData}>
  <div class="post-card-inner">
    <div class="post-meta">
      <a class="post-category" href={topicUrl}>{categoryLabels[primaryCat] || primaryCat}</a>
      <time class="post-date" datetime={data.date}>{data.date}</time>
    </div>
    
    <h2 class="post-title"><a href={postUrl}>{data.title}</a></h2>
    <p class="post-excerpt">{data.excerpt}</p>
    
    <div class="post-footer">
      {data.source && <span class="post-source">{data.source}</span>}
    </div>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    transition: border-color 0.2s ease;
    margin-bottom: 0;
  }

  .post-card::before {
    content: none;
  }

  .post-card:hover {
    border-color: var(--color-rule);
  }

  [data-theme="light"] .post-card:hover {
    border-color: var(--color-rule);
  }

  .post-card-inner {
    position: relative;
    padding: 1.15rem 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .post-category {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0;
    color: var(--color-accent);
    background: transparent;
    padding: 0;
    border-radius: 0;
  }

  [data-theme="light"] .post-category {
    background: transparent;
  }

  .post-date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: 1.12rem;
    font-weight: 600;
    line-height: 1.45;
    margin-bottom: 0.5rem;
    letter-spacing: 0;
  }

  .post-title a {
    color: var(--color-text);
  }

  .post-title a:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .post-excerpt {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.65;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .post-source {
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-weight: 500;
    text-align: right;
  }

  @media (max-width: 640px) {
    .post-meta,
    .post-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .post-source {
      text-align: left;
    }
  }
</style>
