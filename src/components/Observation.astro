---
const { observation, locale, eyebrow } = Astro.props;
const { data, id } = observation;
const slug = id.replace(`${locale}/`, '').replace('.md', '');
const { Content } = await observation.render();
---

<article class="observation" id={`obs-${slug}`}>
  <div class="observation-meta">
    {eyebrow && <span class="observation-eyebrow">{eyebrow}</span>}
    <time class="observation-date" datetime={data.date}>{data.date}</time>
  </div>
  <h3 class="observation-title">{data.title}</h3>
  <div class="observation-body">
    <Content />
  </div>
  {data.tags && data.tags.length > 0 && (
    <div class="observation-tags">
      {data.tags.map((tag: string) => (
        <span class="observation-tag">#{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  .observation {
    position: relative;
    padding: var(--space-md) var(--space-md) var(--space-md) calc(var(--space-md) + 6px);
    border: 1px solid var(--color-card-border);
    border-radius: 12px;
    background: var(--color-card-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    overflow: hidden;
    margin-bottom: 1rem;
    scroll-margin-top: 80px;
  }

  .observation::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: var(--gradient-accent);
  }

  .observation-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .observation-eyebrow {
    color: var(--color-accent);
    text-transform: uppercase;
    font-weight: 600;
  }

  .observation-date {
    color: var(--color-text-muted);
  }

  .observation-title {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .observation-body {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .observation-body :global(p) {
    margin-bottom: var(--space-sm);
  }

  .observation-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .observation-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-color: rgba(212, 168, 67, 0.3);
  }

  .observation-body :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  .observation-body :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .observation-body :global(ul),
  .observation-body :global(ol) {
    margin-left: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .observation-body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .observation-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-sm);
  }

  .observation-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .observation-title {
      font-size: 1.125rem;
    }

    .observation-body {
      font-size: 0.875rem;
    }
  }
</style>
