---
import { getCollection } from 'astro:content';
import BlogPost from '../BlogPost.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('zh');

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.id.startsWith('zh/'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const postsByMonth: Record<string, typeof posts> = {};
posts.forEach(post => {
  const monthKey = post.data.date.substring(0, 7);
  if (!postsByMonth[monthKey]) {
    postsByMonth[monthKey] = [];
  }
  postsByMonth[monthKey].push(post);
});

const sortedMonths = Object.keys(postsByMonth).sort().reverse();

const monthNamesZh: Record<string, string> = {
  '01': '一月', '02': '二月', '03': '三月', '04': '四月',
  '05': '五月', '06': '六月', '07': '七月', '08': '八月',
  '09': '九月', '10': '十月', '11': '十一月', '12': '十二月'
};

function formatMonth(monthKey: string) {
  const [year, month] = monthKey.split('-');
  return `${year}年${monthNamesZh[month]}`;
}
---

<div class="timeline-nav">
  {sortedMonths.map(month => (
    <a href={`#${month}`} class="timeline-link">
      {formatMonth(month)}
      <span class="article-count">({postsByMonth[month].length})</span>
    </a>
  ))}
</div>

<div class="archive-content">
  {sortedMonths.map(month => (
    <section class="month-section" id={month}>
      <h2 class="month-title">
        {formatMonth(month)}
        <span class="month-count">{t('archive.monthCount', { count: postsByMonth[month].length })}</span>
      </h2>
      <div class="posts-grid">
        {postsByMonth[month].map(post => (
          <BlogPost post={post} locale="zh" />
        ))}
      </div>
    </section>
  ))}
</div>

<style>
  .timeline-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: var(--space-md) 0;
    margin-bottom: var(--space-lg);
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
  }

  :global([data-theme="light"]) .timeline-nav {
    background: var(--color-bg);
  }

  .timeline-link {
    padding: 0.4rem 0.75rem;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .timeline-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .article-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }

  .archive-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .month-section {
    scroll-margin-top: 80px;
  }

  .month-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .month-count {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 640px) {
    .timeline-nav {
      overflow-x: auto;
      flex-wrap: nowrap;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .timeline-nav::-webkit-scrollbar {
      display: none;
    }

    .month-title {
      font-size: 1.125rem;
    }
  }
</style>
