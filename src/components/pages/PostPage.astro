---
import { getCollection, render } from 'astro:content';
import { getCategories } from '../../lib/categories.js';
import Layout from '../../layouts/Layout.astro';

const { locale } = Astro.props;
const { slug } = Astro.params;

const allPosts = await getCollection('posts');
const postEntry = allPosts.find(p => p.id === `${locale}/${slug}.md`);

if (!postEntry) {
  return new Response('Not Found', { status: 404 });
}

const { Content } = await render(postEntry);
const post = postEntry.data;
const categories = getCategories(post.tags, post.category);
const originalLinkMatch = postEntry.body?.match(/\[阅读原文\]\(([^)]+)\)\s*$/);
const originalUrl = originalLinkMatch?.[1];

const siteURL = 'https://agenteconomy.cn';
const articleUrl = `${siteURL}/blog/${slug}`;
const description = post.excerpt;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "datePublished": post.date,
  "dateModified": post.date,
  "description": description,
  "image": `${siteURL}/og-image.png`,
  "url": articleUrl,
  "author": { "@type": "Organization", "name": post.source },
  "publisher": {
    "@type": "Organization",
    "name": "Agent Economy",
    "logo": { "@type": "ImageObject", "url": `${siteURL}/logo.png` }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": articleUrl }
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
    { "@type": "ListItem", "position": 2, "name": "Articles", "item": `${siteURL}/blog/` },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": articleUrl }
  ]
});
---

<Layout
  title={post.title}
  description={description}
  type="article"
  publishedTime={post.date}
  tags={post.tags}
  author={post.source}
>
  <script type="application/ld+json" set:html={articleSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <article class:list={['article-content', { 'has-original-link': originalUrl }]}>
    <h1>{post.title}</h1>
    <time datetime={post.date}>{post.date}</time>
    <Content />
  </article>
  <nav class="post-actions" aria-label="文章导航">
    {originalUrl && (
      <a href={originalUrl} class="back-link" target="_blank" rel="noopener noreferrer">阅读原文</a>
    )}
    {originalUrl && <span class="post-action-separator" aria-hidden="true"></span>}
    <a href="/" class="back-link">← 全部文章</a>
  </nav>
</Layout>

<style>
  :global(.article-content.has-original-link > p:last-child:has(> a:only-child)) {
    display: none;
  }

  .post-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }

  .post-actions .back-link {
    margin-top: 0;
  }

  .post-action-separator {
    width: 1px;
    height: 0.85em;
    background: var(--color-border);
  }
</style>
