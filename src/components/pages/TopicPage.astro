---
import { getCollection } from 'astro:content';
import BlogPost from '../BlogPost.astro';
import {
  getRelatedTags,
  getTopSources,
  getTopicBySlug,
  getTopicRssPath,
  postMatchesTopic,
} from '../../lib/categories.js';
import { getLocalizedPath, useTranslations } from '../../i18n/utils';

const { locale, slug } = Astro.props;
const t = useTranslations(locale);
const topic = getTopicBySlug(slug);

if (!topic) {
  return Astro.redirect('/404');
}

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.id.startsWith(`${locale}/`))
  .filter(post => postMatchesTopic(post.data.tags || [], topic))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const tags = getRelatedTags(posts, topic).slice(0, 12);
const sources = getTopSources(posts, 6);
const latestDate = posts[0]?.data.date;
---

<section class="topic-header">
  <a href={getLocalizedPath('/topics', locale)} class="topic-back">← {t('topics.back')}</a>
  <p class="topic-eyebrow">{t('topics.eyebrow')}</p>
  <h1 class="topic-title">{topic.labels[locale]}</h1>
  <p class="topic-desc">{topic.descriptions[locale]}</p>
  <div class="topic-stats">
    <span>{t('topics.articleCount', { count: posts.length })}</span>
    {latestDate && <span>{t('topics.latest', { date: latestDate })}</span>}
    <a href={getTopicRssPath(topic, locale)}>{t('topics.rss')}</a>
  </div>
</section>

<section class="topic-insights" aria-label={t('topics.insights')}>
  <div class="insight-block">
    <h2>{t('topics.relatedTags')}</h2>
    {tags.length > 0 ? (
      <div class="insight-tags">
        {tags.map(tag => <span>#{tag}</span>)}
      </div>
    ) : (
      <p>{t('topics.empty')}</p>
    )}
  </div>
  <div class="insight-block">
    <h2>{t('topics.topSources')}</h2>
    {sources.length > 0 ? (
      <div class="source-list">
        {sources.map(({ source, count }) => (
          <span><strong>{source}</strong> {t('topics.sourceCount', { count })}</span>
        ))}
      </div>
    ) : (
      <p>{t('topics.empty')}</p>
    )}
  </div>
</section>

<section class="topic-posts" aria-label={t('topics.posts')}>
  <h2>{t('topics.posts')}</h2>
  {posts.length > 0 ? (
    <div class="posts-grid">
      {posts.map(post => <BlogPost post={post} locale={locale} />)}
    </div>
  ) : (
    <div class="topic-empty">{t('topics.empty')}</div>
  )}
</section>

<style>
  .topic-header {
    padding: var(--space-lg) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .topic-back {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    margin-bottom: var(--space-md);
  }

  .topic-back:hover {
    color: var(--color-accent);
  }

  .topic-eyebrow {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .topic-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .topic-desc {
    max-width: 640px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .topic-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-md);
  }

  .topic-stats span,
  .topic-stats a {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.35rem 0.6rem;
  }

  .topic-stats a {
    color: var(--color-accent);
  }

  .topic-insights {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: var(--space-xl);
  }

  .insight-block {
    border: 1px solid var(--color-card-border);
    border-radius: 12px;
    background: var(--color-card-bg);
    padding: 1rem;
  }

  .insight-block h2,
  .topic-posts h2 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-sm);
  }

  .insight-block p,
  .topic-empty {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .insight-tags,
  .source-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .insight-tags span,
  .source-list span {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
  }

  .source-list strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 640px) {
    .topic-title {
      font-size: 1.75rem;
    }

    .topic-insights {
      grid-template-columns: 1fr;
    }
  }
</style>
