---
import { getCollection } from 'astro:content';
import BlogPost from '../BlogPost.astro';
import {
  getTopSources,
  getTopicBySlug,
  postMatchesTopic,
} from '../../lib/categories.js';
import { useTranslations } from '../../i18n/utils';

const { slug } = Astro.props;
const t = useTranslations('zh');
const topic = getTopicBySlug(slug);

if (!topic) {
  return Astro.redirect('/404');
}

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.id.startsWith('zh/'))
  .filter(post => postMatchesTopic(post.data.tags || [], topic))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const sources = getTopSources(posts, 6);
---

<section class="topic-header">
  <a href="/topics" class="topic-back">← {t('topics.back')}</a>
  <h1 class="topic-title">{topic.label}</h1>
  <p class="topic-desc">{topic.description}</p>
</section>

<section class="topic-insights" aria-label={t('topics.insights')}>
  <div class="insight-block">
    <h2>{t('topics.topSources')}</h2>
    {sources.length > 0 ? (
      <div class="source-list">
        {sources.map(({ source, count }) => (
          <span><strong>{source}</strong> {t('topics.sourceCount', { count })}</span>
        ))}
      </div>
    ) : (
      <p>{t('topics.empty')}</p>
    )}
  </div>
</section>

<section class="topic-posts" aria-label={t('topics.posts')}>
  <h2>{t('topics.posts')}</h2>
  {posts.length > 0 ? (
    <div class="posts-grid">
      {posts.map(post => <BlogPost post={post} locale="zh" />)}
    </div>
  ) : (
    <div class="topic-empty">{t('topics.empty')}</div>
  )}
</section>

<style>
  .topic-header {
    padding: var(--space-lg) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .topic-back {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    margin-bottom: var(--space-md);
  }

  .topic-back:hover {
    color: var(--color-accent);
  }

  .topic-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: 0;
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .topic-desc {
    max-width: 640px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .topic-insights {
    display: block;
    margin-bottom: var(--space-xl);
  }

  .insight-block {
    border: 1px solid var(--color-card-border);
    border-radius: 6px;
    background: var(--color-card-bg);
    padding: 1rem;
  }

  .insight-block h2,
  .topic-posts h2 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0;
    margin-bottom: var(--space-sm);
  }

  .insight-block p,
  .topic-empty {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .source-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .source-list span {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
  }

  .source-list strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  @media (max-width: 640px) {
    .topic-title {
      font-size: 1.75rem;
    }

  }
</style>
