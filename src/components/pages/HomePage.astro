---
import { getCollection } from 'astro:content';
import {
  categoryLabels,
  getCategories,
  getTopicPath,
  topics,
} from '../../lib/categories.js';
import { useTranslations } from '../../i18n/utils';

const { locale } = Astro.props;
const t = useTranslations(locale);

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const allObservations = await getCollection('observations');
const latestObservation = allObservations
  .filter(o => o.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))[0];

let LatestObservationContent;
if (latestObservation) {
  const rendered = await latestObservation.render();
  LatestObservationContent = rendered.Content;
}

const latestObservationSlug = latestObservation
  ? latestObservation.id.replace(`${locale}/`, '').replace(/\.mdx?$/, '')
  : '';

const categorySections = topics
  .map(topic => {
    const categoryPosts = posts.filter(post =>
      getCategories(post.data.tags || [], post.data.category).includes(topic.key)
    );

    return {
      topic,
      label: categoryLabels[topic.key] || topic.label,
      count: categoryPosts.length,
      posts: categoryPosts.slice(0, 8),
    };
  })
  .filter(section => section.posts.length > 0);

function getPostSlug(post) {
  return post.id.replace(`${locale}/`, '').replace(/\.mdx?$/, '');
}

function getPostUrl(post) {
  return `/blog/${getPostSlug(post)}`;
}
---

<div class="minimal-home">
  {latestObservation && LatestObservationContent && (
    <section class="latest-observation" aria-label={t('observations.latest')}>
      <article>
        <div class="observation-meta">
          <span>{t('observations.latest')}</span>
          <span class="meta-separator" aria-hidden="true"></span>
          <time datetime={latestObservation.data.date}>{latestObservation.data.date}</time>
        </div>
        <h3>
          <a href={`/observations#obs-${latestObservationSlug}`}>
            {latestObservation.data.title}
          </a>
        </h3>
        <div class="observation-body">
          <LatestObservationContent />
        </div>
      </article>
    </section>
  )}

  <section class="category-index" aria-label="分类文章">
    <div class="section-heading">
      <h2>文章分类</h2>
      <a href="/archive">{t('viewAll')}</a>
    </div>

    <div class="category-list">
      {categorySections.map(section => (
        <section class="category-section">
          <header class="category-header">
            <h3>
              <a href={getTopicPath(section.topic)}>{section.label}</a>
            </h3>
          </header>

          <ol class="post-list">
            {section.posts.map(post => (
              <li>
                <time datetime={post.data.date}>{post.data.date}</time>
                <a href={getPostUrl(post)}>{post.data.title}</a>
              </li>
            ))}
          </ol>

          {section.count > section.posts.length && (
            <a class="topic-more" href={getTopicPath(section.topic)}>
              查看更多
            </a>
          )}
        </section>
      ))}
    </div>
  </section>
</div>

<style>
  :global(main) {
    max-width: var(--max-width);
    padding-top: var(--space-lg);
  }

  .minimal-home {
    display: grid;
    gap: var(--space-xl);
  }

  h1,
  h2,
  h3 {
    color: var(--color-text);
    letter-spacing: 0;
    text-wrap: balance;
  }

  .latest-observation,
  .category-index {
    display: grid;
    gap: var(--space-md);
  }

  .section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
  }

  .section-heading a,
  .topic-more {
    color: var(--color-text-muted);
    font-size: 0.86rem;
    text-decoration: underline;
    text-decoration-color: var(--color-border);
    text-underline-offset: 0.18em;
  }

  .section-heading a:hover,
  .topic-more:hover,
  .category-header a:hover,
  .post-list a:hover,
  .latest-observation h3 a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .latest-observation article {
    padding: var(--space-md) 0;
  }

  .observation-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .observation-meta time {
    font: inherit;
    color: inherit;
  }

  .meta-separator {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-text-muted);
    opacity: 0.55;
  }

  .latest-observation h3 {
    margin: 0 0 0.85rem;
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 4vw, 1.9rem);
    font-weight: 700;
    line-height: 1.32;
  }

  .observation-body {
    color: var(--color-text);
    font-size: 0.98rem;
    line-height: 1.85;
  }

  .observation-body :global(p) {
    margin: 0 0 0.9rem;
  }

  .observation-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .observation-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .category-list {
    display: grid;
    gap: var(--space-lg);
  }

  .category-section {
    padding-bottom: var(--space-lg);
  }

  .category-header {
    margin-bottom: 0.9rem;
  }

  .category-header h3 {
    margin: 0;
    font-size: 1.12rem;
    font-weight: 700;
  }

  .post-list {
    display: grid;
    gap: 0.55rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-list li {
    display: grid;
    grid-template-columns: 6.2rem minmax(0, 1fr);
    gap: 0.85rem;
    align-items: baseline;
    line-height: 1.55;
  }

  .post-list time {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .post-list a {
    color: var(--color-text);
    overflow-wrap: anywhere;
  }

  .topic-more {
    display: inline-block;
    margin-top: 0.9rem;
  }

  @media (max-width: 640px) {
    :global(main) {
      padding-top: var(--space-md);
    }

    .minimal-home {
      gap: var(--space-lg);
    }

    .section-heading {
      align-items: flex-start;
    }

    .post-list li {
      grid-template-columns: 1fr;
      gap: 0.1rem;
    }
  }
</style>
