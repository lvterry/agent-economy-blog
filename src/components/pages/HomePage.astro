---
import { getCollection } from 'astro:content';
import BlogPost from '../BlogPost.astro';
import Observation from '../Observation.astro';
import { categoryMap, categoryLabels, getTopicByKey, getTopicPath } from '../../lib/categories.js';
import { useTranslations } from '../../i18n/utils';

const { locale } = Astro.props;
const t = useTranslations(locale);

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => p.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const HOMEPAGE_POST_COUNT = 12;
const totalPostCount = posts.length;

const allObservations = await getCollection('observations');
const latestObservation = allObservations
  .filter(o => o.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))[0];

const allCategories = ['__all', ...Object.keys(categoryMap)];
---

<section class="hero">
  <h2 class="hero-title" style="white-space: pre-line;">{t('hero.title')}</h2>
  <p class="hero-desc">{t('hero.desc')}</p>
</section>

{latestObservation && (
  <section class="latest-observation">
    <Observation
      observation={latestObservation}
      locale={locale}
      eyebrow={t('observations.latest')}
      archiveUrl="/observations"
      archiveLabel={t('observations.viewAll')}
    />
  </section>
)}

<div class="category-filter" id="category-filter">
  {allCategories.map(cat => (
    <button
      data-category={cat}
      data-topic-url={cat === '__all' ? '/topics' : getTopicPath(getTopicByKey(cat) || cat)}
      class:list={['filter-pill', { active: cat === '__all' }]}
      title={cat === '__all' ? t('topics.title') : `${t('topics.title')}: ${categoryLabels[cat] || cat}`}
    >
      {cat === '__all' ? t('filter.all') : categoryLabels[cat] || cat}
    </button>
  ))}
</div>

<section class="posts-grid" id="posts-grid">
  {posts.map((post, index) => (
    <div
      class="post-item"
      data-extra={index >= HOMEPAGE_POST_COUNT ? 'true' : null}
      style={index >= HOMEPAGE_POST_COUNT ? 'display:none' : undefined}
    >
      <BlogPost post={post} locale={locale} />
    </div>
  ))}
</section>

{totalPostCount > HOMEPAGE_POST_COUNT && (
  <div class="view-all-section" id="view-all-section">
    <div class="post-count">{t('postCount', { shown: HOMEPAGE_POST_COUNT, total: totalPostCount })}</div>
    <a href="/archive" class="view-all-btn">{t('viewAll')} →</a>
  </div>
)}

<div class="empty-state" id="empty-state" style="display:none">
  {t('emptyState')}
</div>

<style>
  .hero {
    text-align: center;
    padding: var(--space-lg) 0 var(--space-xl);
    margin-bottom: var(--space-lg);
    position: relative;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gradient-accent);
    border-radius: 1px;
    opacity: 0.5;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto var(--space-lg);
  }

  .latest-observation {
    margin-bottom: var(--space-lg);
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    padding-top: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(12, 10, 9, 0.82);
  }

  :global([data-theme="light"]) .category-filter {
    background: rgba(245, 240, 232, 0.85);
  }

  .filter-pill {
    padding: 0.4rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: transparent;
    transition: all 0.2s ease;
    cursor: pointer;
    letter-spacing: 0.01em;
  }

  .filter-pill:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .filter-pill.active {
    background: var(--gradient-accent);
    color: #fff;
    border-color: transparent;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl) 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .view-all-section {
    text-align: center;
    padding: var(--space-xl) 0;
    margin-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .post-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .view-all-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--gradient-accent);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .view-all-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(212, 168, 67, 0.3);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }

    .hero-desc {
      font-size: 0.875rem;
    }

    .category-filter {
      overflow-x: auto;
      flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: var(--space-sm);
    }

    .category-filter::-webkit-scrollbar {
      display: none;
    }

    .filter-pill {
      white-space: nowrap;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('#category-filter .filter-pill');
  const postsGrid = document.getElementById('posts-grid');
  const emptyState = document.getElementById('empty-state');
  const viewAllSection = document.getElementById('view-all-section');
  const items = postsGrid ? postsGrid.querySelectorAll('.post-item') : [];

  function filterPosts(category) {
    const isAll = category === '__all';
    let visibleCount = 0;
    items.forEach((item) => {
      const el = item as HTMLElement;
      const card = el.querySelector('.post-card') as HTMLElement | null;
      const cats = card?.dataset.categories || '';
      const isExtra = el.dataset.extra === 'true';
      const show = isAll ? !isExtra : cats.split(',').includes(category);
      el.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });
    if (emptyState) {
      emptyState.style.display = visibleCount === 0 ? '' : 'none';
    }
    if (viewAllSection) {
      viewAllSection.style.display = isAll ? '' : 'none';
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const category = (btn as HTMLElement).dataset.category || '__all';
      filterPosts(category);
    });
  });

  filterPosts('__all');
</script>
