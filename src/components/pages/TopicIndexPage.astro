---
import { getCollection } from 'astro:content';
import { topics, getTopicPath, postMatchesTopic, packTopicBubbles } from '../../lib/categories.js';
import { useTranslations } from '../../i18n/utils';

const { locale } = Astro.props;
const t = useTranslations(locale);

const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => p.id.startsWith(`${locale}/`));

const topicCounts = topics.map(topic => ({
  topic,
  count: posts.filter(post => postMatchesTopic(post.data.tags || [], topic)).length,
}));

const VIEW_W = 1000;
const VIEW_H = 640;
const MIN_R = 60;
const MAX_R = 150;
const maxCount = Math.max(1, ...topicCounts.map(c => c.count));

const bubbleInputs = topicCounts.map(({ topic, count }) => ({
  id: topic.slug,
  r: count === 0 ? MIN_R : MIN_R + (MAX_R - MIN_R) * Math.sqrt(count / maxCount),
}));

const packed = packTopicBubbles(bubbleInputs, { width: VIEW_W, height: VIEW_H, padding: 8 });
const packedById = new Map(packed.map(p => [p.id, p]));

function textColorFor(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const lin = (c: number) => (c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4));
  const luminance = 0.2126 * lin(r) + 0.7152 * lin(g) + 0.0722 * lin(b);
  return luminance > 0.45 ? '#1a1d2e' : '#fdfaf3';
}

const bubbles = topicCounts.map(({ topic, count }) => {
  const p = packedById.get(topic.slug)!;
  const labelLength = topic.labels[locale].length;
  const fontSize = Math.max(14, Math.min(22, p.r / Math.max(3.8, labelLength * 0.48)));
  const arcRadius = Math.max(p.r * 0.4, p.r - fontSize - 16);
  const arcCy = p.y;
  const arcD = `M ${p.x - arcRadius} ${arcCy} A ${arcRadius} ${arcRadius} 0 0 1 ${p.x + arcRadius} ${arcCy}`;
  const textColor = textColorFor(topic.color);
  const countColor = textColor === '#fdfaf3' ? 'rgba(253, 250, 243, 0.78)' : 'rgba(26, 29, 46, 0.7)';
  return { topic, count, ...p, arcD, fontSize, textColor, countColor };
});
---

<section class="topics-header">
  <p class="topics-eyebrow">{t('topics.eyebrow')}</p>
  <h1 class="topics-title">{t('topics.title')}</h1>
  <p class="topics-desc">{t('topics.desc')}</p>
</section>

<section class="topics-bubbles" aria-label={t('topics.title')}>
  <svg
    viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
    role="list"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      {bubbles.map(b => (
        <path id={`arc-${b.topic.slug}`} d={b.arcD} fill="none" />
      ))}
    </defs>
    {bubbles.map((b, i) => (
      <a
        href={getTopicPath(b.topic, locale)}
        role="listitem"
        aria-label={`${b.topic.labels[locale]} — ${t('topics.articleCount', { count: b.count })}`}
        class:list={["bubble", b.count === 0 && "bubble-empty"]}
        style={`--bubble-color: ${b.topic.color}; --bubble-cx: ${b.x}px; --bubble-cy: ${b.y}px; --bubble-delay: ${i * 0.04}s;`}
      >
        <circle cx={b.x} cy={b.y} r={b.r} fill={b.topic.color} />
        <text class="bubble-label" font-size={b.fontSize} fill={b.textColor}>
          <textPath href={`#arc-${b.topic.slug}`} startOffset="50%" text-anchor="middle">
            {b.topic.labels[locale]}
          </textPath>
        </text>
        <text
          x={b.x}
          y={b.y + 6}
          text-anchor="middle"
          class="bubble-count"
          fill={b.countColor}
          font-size={Math.max(12, b.r / 6.5)}
        >
          {t('topics.articleCount', { count: b.count })}
        </text>
      </a>
    ))}
  </svg>

  <ul class="topics-fallback">
    {bubbles.map(({ topic, count }) => (
      <li>
        <a href={getTopicPath(topic, locale)}>
          {topic.labels[locale]} — {t('topics.articleCount', { count })}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .topics-header {
    padding: var(--space-lg) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .topics-eyebrow {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .topics-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .topics-desc {
    max-width: 620px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .topics-bubbles {
    margin: 0 auto;
    max-width: 1100px;
  }

  .topics-bubbles svg {
    width: 100%;
    height: auto;
    max-height: 78vh;
    display: block;
    overflow: visible;
  }

  @keyframes bubble-in {
    0%   { transform: scale(0.2); opacity: 0; }
    60%  { transform: scale(1.08); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes bubble-in-empty {
    0%   { transform: scale(0.2); opacity: 0; }
    60%  { transform: scale(1.08); opacity: 0.55; }
    100% { transform: scale(1); opacity: 0.55; }
  }

  @keyframes ring-pulse {
    0%, 100% { stroke-width: 2; stroke-opacity: 0.55; }
    50%      { stroke-width: 6; stroke-opacity: 0.15; }
  }

  .bubble {
    cursor: pointer;
    transform-origin: var(--bubble-cx) var(--bubble-cy);
    transition: transform 0.25s ease, filter 0.25s ease;
    animation: bubble-in 520ms cubic-bezier(0.34, 1.56, 0.64, 1) var(--bubble-delay, 0s) both;
  }

  .bubble circle {
    transition: filter 0.25s ease, stroke-width 0.25s ease, stroke-opacity 0.25s ease;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.08));
  }

  .bubble:hover {
    transform: scale(1.06);
    filter: saturate(1.15) brightness(1.04);
  }

  .bubble:hover circle {
    filter: drop-shadow(0 10px 30px rgba(0, 0, 0, 0.22));
    stroke: var(--bubble-color);
    stroke-width: 2;
    stroke-opacity: 0.55;
    animation: ring-pulse 1.4s ease-in-out infinite;
  }

  .bubble:focus-visible {
    outline: none;
  }

  .bubble:focus-visible circle {
    stroke: var(--color-accent);
    stroke-width: 3;
  }

  .bubble-empty {
    opacity: 0.55;
    animation-name: bubble-in-empty;
  }

  .bubble-label {
    font-weight: 600;
    letter-spacing: -0.01em;
    pointer-events: none;
  }

  .bubble-count {
    font-family: var(--font-mono);
    pointer-events: none;
  }

  .topics-fallback {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .bubble,
    .bubble circle {
      transition: none;
      animation: none;
    }
    .bubble:hover {
      transform: none;
      filter: none;
    }
    .bubble:hover circle {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .topics-title {
      font-size: 1.75rem;
    }

    .topics-bubbles svg {
      max-height: none;
    }
  }
</style>
