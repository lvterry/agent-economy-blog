---
import { getCollection } from 'astro:content';
import { topics, getTopicPath, postMatchesTopic, getRelatedTags } from '../../lib/categories.js';
import { useTranslations } from '../../i18n/utils';

const { locale } = Astro.props;
const t = useTranslations(locale);

const allPosts = await getCollection('posts');
const posts = allPosts.filter(p => p.id.startsWith(`${locale}/`));

const topicCards = topics.map(topic => {
  const topicPosts = posts.filter(post => postMatchesTopic(post.data.tags || [], topic));
  return {
    topic,
    posts: topicPosts,
    tags: getRelatedTags(topicPosts, topic).slice(0, 5),
    latestDate: topicPosts.sort((a, b) => b.data.date.localeCompare(a.data.date))[0]?.data.date,
  };
});
---

<section class="topics-header">
  <p class="topics-eyebrow">{t('topics.eyebrow')}</p>
  <h1 class="topics-title">{t('topics.title')}</h1>
  <p class="topics-desc">{t('topics.desc')}</p>
</section>

<section class="topics-grid" aria-label={t('topics.title')}>
  {topicCards.map(({ topic, posts, tags, latestDate }) => (
    <a class="topic-card" href={getTopicPath(topic, locale)}>
      <div class="topic-card-header">
        <h2>{topic.labels[locale]}</h2>
        <span class="topic-count">{t('topics.articleCount', { count: posts.length })}</span>
      </div>
      <p>{topic.descriptions[locale]}</p>
      <div class="topic-meta">
        {latestDate && <span>{t('topics.latest', { date: latestDate })}</span>}
        {!latestDate && <span>{t('topics.empty')}</span>}
      </div>
      {tags.length > 0 && (
        <div class="topic-tags" aria-label={t('topics.relatedTags')}>
          {tags.map(tag => <span>#{tag}</span>)}
        </div>
      )}
    </a>
  ))}
</section>

<style>
  .topics-header {
    padding: var(--space-lg) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .topics-eyebrow {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xs);
  }

  .topics-title {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .topics-desc {
    max-width: 620px;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    min-height: 220px;
    padding: 1.25rem;
    border: 1px solid var(--color-card-border);
    border-radius: 12px;
    background: var(--color-card-bg);
    transition: all 0.2s ease;
  }

  .topic-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
    box-shadow: 0 4px 24px rgba(212, 168, 67, 0.06);
  }

  .topic-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: var(--space-sm);
  }

  .topic-card h2 {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .topic-count {
    flex-shrink: 0;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    background: var(--color-accent-glow);
    border-radius: 4px;
    padding: 0.2rem 0.45rem;
  }

  .topic-card p {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: auto;
  }

  .topic-meta {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .topic-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: var(--space-sm);
  }

  .topic-tags span {
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .topics-title {
      font-size: 1.75rem;
    }

    .topics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
