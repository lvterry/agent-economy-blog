---
import { getCollection } from 'astro:content';
import Observation from '../Observation.astro';
import { useTranslations } from '../../i18n/utils';

const { locale } = Astro.props;
const t = useTranslations(locale);

const allObservations = await getCollection('observations');
const observations = allObservations
  .filter(o => o.id.startsWith(`${locale}/`))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<section class="archive-header">
  <h1 class="archive-title">{t('observations.title')}</h1>
  <p class="archive-stats">{t('observations.count', { count: observations.length })}</p>
</section>

{observations.length === 0 ? (
  <div class="empty-state">{t('observations.empty')}</div>
) : (
  <div class="observations-list">
    {observations.map(obs => (
      <Observation observation={obs} locale={locale} />
    ))}
  </div>
)}

<style>
  .archive-header {
    text-align: center;
    padding: var(--space-lg) 0 var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .archive-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .archive-stats {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .observations-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl) 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .archive-title {
      font-size: 1.5rem;
    }
  }
</style>
