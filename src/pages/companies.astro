---
import Layout from '../layouts/Layout.astro';
import { companies, categories } from '../data/companies';
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale || 'zh';
const t = useTranslations(locale);
---

<Layout>
  <section class="intro">
    <h2>{locale === 'zh' ? 'AI 行业领先公司' : 'Leading AI Companies'}</h2>
    <p>{locale === 'zh' ? '探索塑造智能体经济的核心企业，从基础设施提供商到应用开发者。' : 'Explore the core enterprises shaping the agent economy, from infrastructure providers to application developers.'}</p>
  </section>

  <section class="companies-section">
    <div class="category-filter">
      {categories.map(cat => (
        <button 
          class={`filter-btn ${cat.id === 'all' ? 'active' : ''}`} 
          data-category={cat.id}
        >
          {locale === 'zh' ? cat.nameZh : cat.nameEn}
        </button>
      ))}
    </div>

    <div class="companies-grid">
      {companies.map(company => (
        <a 
          href={company.website} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="company-card"
          data-category={company.category}
        >
          <div class="company-logo">
            <img src={company.logo} alt={`${company.name} logo`} loading="lazy" />
          </div>
          <div class="company-info">
            <h3 class="company-name">{company.name}</h3>
            <span class="company-category">{locale === 'zh' ? company.categoryZh : company.category}</span>
            <p class="company-description">{locale === 'zh' ? company.descriptionZh : company.descriptionEn}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .intro {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .intro h2 {
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--space-sm);
    letter-spacing: -0.03em;
  }

  .intro p {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .filter-btn {
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--color-text-secondary);
  }

  .filter-btn:hover {
    border-color: var(--color-text);
    color: var(--color-text);
  }

  .filter-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .companies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .company-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: all 0.2s ease;
    background: var(--color-card-bg);
  }

  .company-card:hover {
    border-color: var(--color-text);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    opacity: 1;
  }

  .company-card.hidden {
    display: none;
  }

  .company-logo {
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .company-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .company-info {
    flex: 1;
  }

  .company-name {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
  }

  .company-category {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
    display: block;
  }

  .company-description {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .companies-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const companyCards = document.querySelectorAll('.company-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = btn.dataset.category;
        
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        
        companyCards.forEach(card => {
          if (category === 'all' || card.dataset.category === category) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  })();
</script>
