---
import Layout from '../layouts/Layout.astro';
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale || 'zh';
const t = useTranslations(locale);
---

<Layout title="404 - Page Not Found" description="The page you are looking for does not exist.">
  <div class="not-found">
    <h1 class="error-code">404</h1>
    <p class="error-message">{t('404.message')}</p>
    <a href={locale === 'zh' ? '/' : '/en/'} class="back-home">{t('404.back')}</a>
  </div>
</Layout>

<style>
  .not-found {
    text-align: center;
    padding: var(--space-xl) 0;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.05em;
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .error-message {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .back-home {
    display: inline-block;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  @media (max-width: 640px) {
    .error-code {
      font-size: 4rem;
    }
  }
</style>
