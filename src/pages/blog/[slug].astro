const descriptionEn = post.contentEn.replace(/<[^>]*>/g, '').slice(0, 160).trim() + '...';
const description = `${post.titleEn} - ${descriptionEn}`;
const articleUrl = `${siteURL}/blog/${slug}`;

// JSON-LD for article
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.titleEn,
  "datePublished": post.date,
  "dateModified": post.date,
  "description": descriptionEn,
  "image": `${siteURL}/og-image.png`,
  "url": articleUrl,
  "author": {
    "@type": "Organization",
    "name": post.source
  },
  "publisher": {
    "@type": "Organization",
    "name": "Agent Economy",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteURL}/favicon.svg`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  }
});

// JSON-LD for breadcrumb
const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteURL
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Articles",
      "item": `${siteURL}/blog/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.titleEn,
      "item": articleUrl
    }
  ]
});
