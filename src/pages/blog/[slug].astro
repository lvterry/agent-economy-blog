  title={post.titleEn}
  description={description}
  type="article"
  publishedTime={post.date}
  tags={post.tags}
  author={post.source}
>
  <script type="application/ld+json" set:html={articleSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <article class="article-content">
    <div class="lang-content lang-zh active">
      <h1>{post.titleZh}</h1>
    </div>
    <div class="lang-content lang-en">
      <h1>{post.titleEn}</h1>
    </div>
    <time>{post.date}</time>
    
    <div class="lang-content lang-zh active" set:html={post.contentZh} />
    <div class="lang-content lang-en" set:html={post.contentEn} />
  </article>
  
  <a href="/" class="back-link" data-zh="← 全部文章" data-en="← All articles">← All articles</a>
</Layout>
