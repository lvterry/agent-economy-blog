---
import Layout from '../../layouts/Layout.astro';

const title = 'All Notes';
const description = 'Complete archive of notes and observations about AI agents and the emerging economy.';

const notes = [
  {
    slug: 'codex-for-almost-everything-openai',
    contentZh: 'OpenAI 的 Codex 更新值得关注。计算机操作、图像生成、PR 审查——这些功能让 AI 更接近一个真正的开发伙伴。',
    contentEn: 'OpenAI\'s Codex update is worth watching. Computer use, image generation, PR reviews — these features bring AI closer to being a true dev partner.',
    date: '2026-04-16',
    tags: ['OpenAI', 'Codex', 'AI-Agents'],
    source: 'OpenAI'
  },
  {
    slug: 'introducing-claude-opus-47-anthropic',
    contentZh: 'Claude Opus 4.7 发布了。Anthropic 在模型能力上的迭代速度令人印象深刻。',
    contentEn: 'Claude Opus 4.7 is out. Anthropic\'s iteration speed on model capabilities is impressive.',
    date: '2026-04-16',
    tags: ['Anthropic', 'Claude'],
    source: 'Anthropic'
  },
  {
    slug: 'the-gemini-app-is-now-available-on-mac-os',
    contentZh: 'Google 把 Gemini 带到了 Mac。桌面端的 AI 助手竞争越来越激烈了。',
    contentEn: 'Google brings Gemini to Mac. The competition for desktop AI assistants is heating up.',
    date: '2026-04-16',
    tags: ['Google', 'Gemini', 'MacOS'],
    source: 'Google'
  },
  {
    slug: 'skills-in-chrome-ai-workflows',
    contentZh: 'Chrome 的 Skills 功能很有意思——把常用的 AI 提示保存成一键工具。这种「可编程的浏览器」思路可能会改变用户与 AI 的交互方式。',
    contentEn: 'Chrome\'s Skills feature is interesting — saving common AI prompts as one-click tools. This "programmable browser" approach might change how users interact with AI.',
    date: '2026-04-15',
    tags: ['Google', 'Chrome', 'Productivity'],
    source: 'Google'
  },
  {
    slug: 'stanford-report-ai-insiders-public-disconnect',
    contentZh: '斯坦福的报告显示 AI 圈内和圈外的认知差距在扩大。Gen Z 对 AI 的态度更负面——这是一个值得关注的信号。',
    contentEn: 'Stanford report shows the perception gap between AI insiders and the public is widening. Gen Z\'s more negative attitude toward AI is a signal worth watching.',
    date: '2026-04-14',
    tags: ['Stanford', 'AI-Policy', 'Society'],
    source: 'TechCrunch'
  },
  {
    slug: 'how-the-ai-loser-may-end-up-winning',
    contentZh: '当所有人都在烧钱抢 SOTA 时，苹果在积累现金。如果智能真的商品化，「输家」可能反而赢了。',
    contentEn: 'While everyone burns cash for SOTA, Apple accumulates cash. If intelligence commoditizes, the "loser" might actually win.',
    date: '2026-04-13',
    tags: ['Apple', 'Strategy', 'Economy'],
    source: 'adlrocha'
  },
  {
    slug: 'industrial-policy-for-the-intelligence-age',
    contentZh: 'OpenAI 发布政策建议，10 万美元研究资助 + 100 万美元 API 积分。这是在为超级智能时代做政策准备。',
    contentEn: 'OpenAI releases policy recommendations, $100K research grants + $1M API credits. Preparing policy groundwork for the superintelligence era.',
    date: '2026-04-12',
    tags: ['OpenAI', 'Policy', 'Superintelligence'],
    source: 'OpenAI'
  },
  {
    slug: 'linux-kernel-coding-assistants-guidelines',
    contentZh: 'Linux 内核终于对 AI 辅助编程表态：AI 不能签 Signed-off-by，人类负全责。开源社区对 AI 的规范正在形成。',
    contentEn: 'Linux kernel finally weighs in on AI-assisted coding: AI cannot sign Signed-off-by, humans take full responsibility. Open source community norms around AI are forming.',
    date: '2026-04-11',
    tags: ['Linux', 'Open-Source', 'Policy'],
    source: 'Linux Kernel'
  },
  {
    slug: 'a-backend-for-ai-coded-apps',
    contentZh: 'Instant 1.0 把编码智能体变成全栈应用构建器。多租户、同步引擎、完全开源——这是给 AI 时代的后端基础设施。',
    contentEn: 'Instant 1.0 turns coding agents into full-stack app builders. Multi-tenant, sync engine, fully open source — backend infrastructure for the AI era.',
    date: '2026-04-10',
    tags: ['Developer-Tools', 'Backend', 'Open-Source'],
    source: 'Instant'
  },
  {
    slug: 'introducing-muse-spark-scaling-towards-personal-su',
    contentZh: 'Meta 的 Muse Spark 瞄准「个人超级智能」。每个人都拥有自己的 AI 助手——这个愿景正在变成现实。',
    contentEn: 'Meta\'s Muse Spark targets "personal superintelligence". Everyone having their own AI assistant — this vision is becoming reality.',
    date: '2026-04-09',
    tags: ['Meta', 'AI-Agents', 'Personal-AI'],
    source: 'Meta'
  }
];

function groupByMonth(notes) {
  const groups = {};
  notes.forEach(note => {
    const date = new Date(note.date);
    const key = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
    if (!groups[key]) groups[key] = [];
    groups[key].push(note);
  });
  return groups;
}

const groupedNotes = groupByMonth(notes);
---

<Layout title={title} description={description}>
  <div class="notes-archive">
    <header class="archive-header">
      <h1>All Notes</h1>
      <a href="/" class="back-link">← Back to timeline</a>
    </header>

    <div class="archive-content">
      {Object.entries(groupedNotes).map(([month, monthNotes]) => (
        <section class="month-section">
          <h2 class="month-title">{month}</h2>
          <div class="month-notes">
            {monthNotes.map(note => (
              <article class="archive-note">
                <div class="note-date">{note.date}</div>
                <div class="note-body">
                  <p class="lang-content lang-zh active">{note.contentZh}</p>
                  <p class="lang-content lang-en">{note.contentEn}</p>
                </div>
                <div class="note-tags">
                  {note.tags.map(tag => <span class="tag">#{tag}</span>)}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <style>
    .notes-archive {
      max-width: 640px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    .archive-header {
      margin-bottom: 3rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .archive-header h1 {
      font-size: 1.5rem;
      font-weight: 500;
    }

    .back-link {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
    }

    .month-section {
      margin-bottom: 3rem;
    }

    .month-title {
      font-size: 1.1rem;
      font-weight: 500;
      color: var(--color-text-secondary);
      margin-bottom: 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .archive-note {
      padding: 1.25rem 0;
      border-bottom: 1px solid var(--color-border);
    }

    .archive-note:last-child {
      border-bottom: none;
    }

    .note-date {
      font-size: 0.8rem;
      color: var(--color-text-muted);
      margin-bottom: 0.5rem;
    }

    .note-body {
      margin-bottom: 0.75rem;
    }

    .note-body p {
      font-size: 0.95rem;
      line-height: 1.6;
      margin: 0;
    }

    .note-tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }

    .tag {
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    @media (max-width: 640px) {
      .notes-archive {
        padding: 2rem 1rem;
      }

      .archive-header {
        flex-direction: column;
        gap: 0.5rem;
      }
    }
  </style>
</Layout>
