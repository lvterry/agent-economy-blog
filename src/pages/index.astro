---
import Layout from '../layouts/Layout.astro';
import BlogPost from '../components/BlogPost.astro';
import { posts } from '../data/posts';

const title = 'Articles';
const description = 'Latest curated news and insights about AI agents, the agent economy, and autonomous systems.';

const categoryMap = {
  "AI Infra": ["AI-Infrastructure", "Hardware", "Data-Center", "GPU", "TPU", "Supply-Chain", "Infrastructure", "Tinygrad", "Deep-Learning"],
  "AI 模型": ["OpenAI", "Google", "Anthropic", "Claude", "Gemini", "GPT", "Multimodal", "Reasoning", "AI-Model", "Image-Generation", "Foundation Model", "Nano-Banana", "GPT-5.4"],
  "AI 智能体": ["Agent", "Agentic AI", "A2A", "MCP", "AI-Agents", "Agent-Interoperability", "Agent-Economy", "AI-Standards"],
  "AI 应用": ["Product-Design", "AI-Design", "Embodied AI", "Robotics", "Computer-Use", "Coding"],
  "商业 & 经济": ["Agent-Economy", "Market-Analysis", "Business", "Layoffs", "Tech-Industry", "Jack-Dorsey", "Block", "Rent a Human", "Economy", "Risk-Assessment", "Future-of-Work"],
  "安全 & 协议": ["AP2", "AI-Advertising", "Security"],
  "行业动态": ["X/Twitter", "ChatGPT"]
};

const categoryLabelsEn: Record<string, string> = {
  "全部": "All",
  "AI Infra": "AI Infra",
  "AI 模型": "AI Models",
  "AI 智能体": "AI Agents",
  "AI 应用": "AI Apps",
  "商业 & 经济": "Business",
  "安全 & 协议": "Security",
  "行业动态": "Industry"
};

function getCategories(tags: string[]) {
  const categories = new Set<string>();
  const categoryPriority = ["AI Infra", "AI 智能体", "AI 模型", "AI 应用", "商业 & 经济", "安全 & 协议", "行业动态"];
  
  // 先按优先级顺序检查
  for (const category of categoryPriority) {
    const categoryTags = categoryMap[category as keyof typeof categoryMap];
    if (categoryTags && tags.some(tag => categoryTags.includes(tag))) {
      categories.add(category);
    }
  }
  
  // 检查是否有其他未包含的分类
  for (const tag of tags) {
    for (const [category, categoryTags] of Object.entries(categoryMap)) {
      if (categoryTags.includes(tag) && !categories.has(category)) {
        categories.add(category);
      }
    }
  }
  
  if (categories.size === 0) categories.add("AI 智能体");
  return Array.from(categories);
}

const allCategories = ['全部', ...Object.keys(categoryMap)];

// 首页只显示最新12篇文章
const HOMEPAGE_POST_COUNT = 12;
const recentPosts = posts.slice(0, HOMEPAGE_POST_COUNT);
const totalPostCount = posts.length;
---

<Layout title={title} description={description}>
  <section class="hero">
    <h2 class="hero-title">
      <span class="lang-content lang-zh active">智能体正在重塑<br/>经济规则</span>
      <span class="lang-content lang-en">Agents are rewriting<br/>the rules of the economy</span>
    </h2>
    <p class="hero-desc">
      <span class="lang-content lang-zh active">精选 AI 智能体、自主系统与新兴智能体经济的最新新闻与洞察</span>
      <span class="lang-content lang-en">Curated news & insights on AI agents, autonomous systems, and the emerging agent economy</span>
    </p>
  </section>

  <div class="category-filter" id="category-filter">
    {allCategories.map(cat => (
      <button
        data-category={cat}
        class:list={['filter-pill', { active: cat === '全部' }]}
      >
        <span class="lang-content lang-zh active">{cat}</span>
        <span class="lang-content lang-en">{categoryLabelsEn[cat] || cat}</span>
      </button>
    ))}
  </div>

  <section class="posts-grid" id="posts-grid">
    {recentPosts.map(post => (
      <BlogPost {...post} />
    ))}
  </section>

  {totalPostCount > HOMEPAGE_POST_COUNT && (
    <div class="view-all-section">
      <div class="post-count">
        <span class="lang-content lang-zh active">显示最新 {HOMEPAGE_POST_COUNT} 篇，共 {totalPostCount} 篇文章</span>
        <span class="lang-content lang-en">Showing latest {HOMEPAGE_POST_COUNT} of {totalPostCount} articles</span>
      </div>
      <a href="/archive" class="view-all-btn">
        <span class="lang-content lang-zh active">查看全部文章 →</span>
        <span class="lang-content lang-en">View all articles →</span>
      </a>
    </div>
  )}

  <div class="empty-state" id="empty-state" style="display:none">
    <span class="lang-content lang-zh active">暂无该分类的文章</span>
    <span class="lang-content lang-en">No articles in this category</span>
  </div>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-lg) 0 var(--space-xl);
    margin-bottom: var(--space-lg);
    position: relative;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gradient-accent);
    border-radius: 1px;
    opacity: 0.5;
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-sm);
    background: var(--gradient-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 480px;
    margin: 0 auto var(--space-lg);
  }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    padding-top: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(12, 10, 9, 0.82);
  }

  :global([data-theme="light"]) .category-filter {
    background: rgba(245, 240, 232, 0.85);
  }

  .filter-pill {
    padding: 0.4rem 0.875rem;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: transparent;
    transition: all 0.2s ease;
    cursor: pointer;
    letter-spacing: 0.01em;
  }

  .filter-pill:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .filter-pill.active {
    background: var(--gradient-accent);
    color: #fff;
    border-color: transparent;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-2xl) 0;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .view-all-section {
    text-align: center;
    padding: var(--space-xl) 0;
    margin-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .post-count {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .view-all-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--gradient-accent);
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .view-all-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(212, 168, 67, 0.3);
  }

  .lang-content {
    display: none;
  }

  .lang-content.active {
    display: block;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 1.75rem;
    }

    .hero-desc {
      font-size: 0.875rem;
    }

    .stat-value {
      font-size: 1.25rem;
    }

    .category-filter {
      overflow-x: auto;
      flex-wrap: nowrap;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: var(--space-sm);
    }

    .category-filter::-webkit-scrollbar {
      display: none;
    }

    .filter-pill {
      white-space: nowrap;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('#category-filter .filter-pill');
  const postsGrid = document.getElementById('posts-grid');
  const emptyState = document.getElementById('empty-state');
  const posts = postsGrid ? postsGrid.querySelectorAll('.post-card') : [];

  function filterPosts(category: string) {
    let visibleCount = 0;
    posts.forEach((post) => {
      const cats = (post as HTMLElement).dataset.categories || '';
      const show = category === '全部' || cats.split(',').includes(category);
      (post as HTMLElement).style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });
    if (emptyState) {
      emptyState.style.display = visibleCount === 0 ? '' : 'none';
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const category = (btn as HTMLElement).dataset.category || '全部';
      filterPosts(category);
    });
  });
</script>
